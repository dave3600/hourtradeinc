# Copy to ".env.local" and fill values. Never commit .env.local.
# Do not paste the service account JSON blob — use the three FIREBASE_* lines below only.

# Firebase web app (Console → Project settings → Your apps → Web)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (Console → Project settings → Service accounts → Generate new private key JSON)
# FIREBASE_PRIVATE_KEY must be one line with \n for line breaks, e.g. "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
